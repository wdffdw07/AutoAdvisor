<!-- UI/MainWindow.xaml
     职责：极简覆盖层 UI。
     - 全屏无边框透明窗口，默认 WS_EX_TRANSPARENT 全穿透
     - 有 AI 响应时关闭穿透（DisableClickThrough），使按钮可点击
     - Canvas：动态绘制黄框 + Tooltip 标注（DispatcherTimer每100ms跟随剪映窗口）
     - 控制面板：下一步 / 完成 按钮 + 状态文字（AI响应时才显示）
-->
<Window x:Class="CopilotClient.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CopilotOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Grid>
        <!-- ① 全屏画布：动态添加黄框和 Tooltip -->
        <Canvas x:Name="MainCanvas" />

        <!-- ② 顶部状态栏（连接状态提示） -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Background="#CC1A1A1A"
                CornerRadius="6"
                Padding="14,6">
            <TextBlock x:Name="StatusText"
                       Text="● 未连接服务器"
                       Foreground="#FF6B6B"
                       FontSize="13"
                       FontFamily="Microsoft YaHei UI"/>
        </Border>

        <!-- ③ 底部控制面板：F9 提示 + 下一步 + 完成（AI响应后才显示）-->
        <Border x:Name="ControlPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,24"
                Visibility="Collapsed"
                Background="#E61A1A1A"
                CornerRadius="10"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- F9 快捷键提示 -->
                <Border Background="#333333" CornerRadius="4" Padding="6,3" Margin="0,0,10,0">
                    <TextBlock Text="F9" Foreground="#AAAAAA" FontSize="12"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="截图分析"
                           Foreground="#888888" FontSize="13"
                           FontFamily="Microsoft YaHei UI"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- 下一步按钮 -->
                <Button x:Name="BtnNext"
                        Content="下一步 →"
                        Click="BtnNext_Click"
                        Width="90" Height="34"
                        FontSize="13"
                        FontFamily="Microsoft YaHei UI"
                        Foreground="White"
                        Background="#1E90FF"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="10,6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3AA0FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0078D7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 完成按钮 -->
                <Button x:Name="BtnDone"
                        Content="✓ 完成"
                        Click="BtnDone_Click"
                        Width="80" Height="34"
                        FontSize="13"
                        FontFamily="Microsoft YaHei UI"
                        Foreground="White"
                        Background="#28A745"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="10,6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3CB85A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1E7A35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
